{
  "name": "restaurant-saas",
  "version": "1.0.0",
  "private": true,
  "description": "Multi-tenant restaurant POS and order management SaaS monorepo",
  "workspaces": [
    "apps/frontend",
    "apps/backend",
    "shared"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:backend dev:frontend",
    "dev:frontend": "npm run dev -w apps/frontend",
    "dev:backend": "npm run dev -w apps/backend",
    "build": "npm-run-all build:shared build:backend build:frontend",
    "build:frontend": "npm run build -w apps/frontend",
    "build:backend": "npm run build -w apps/backend",
    "build:shared": "npm run build -w shared",
    "lint": "npm-run-all --parallel lint:frontend lint:backend",
    "lint:frontend": "npm run lint -w apps/frontend",
    "lint:backend": "npm run lint -w apps/backend",
    "format": "prettier --write .",
    "typecheck": "npm-run-all --parallel typecheck:shared typecheck:backend typecheck:frontend",
    "typecheck:frontend": "npm run typecheck -w apps/frontend",
    "typecheck:backend": "npm run typecheck -w apps/backend",
    "typecheck:shared": "npm run typecheck -w shared"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=20"
  }
}
